    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const binaryKey = $input.first().binary?.promptFile ? 'promptFile' : 'data';\nconst buf = await this.helpers.getBinaryDataBuffer(0, binaryKey);\nlet raw = buf.toString('utf8').replace(/\\r\\n?/g, '\\n');\nif (!raw.endsWith('\\n')) raw += '\\n';\n\nconst cMatch = raw.match(/shared:\\n\\s+constraints:\\n((?:\\s+-\\s+\"[^\"]*\"\\n)+)/);\nconst constraints = cMatch\n  ? [...cMatch[1].matchAll(/\"([^\"]+)\"/g)].map(m => m[1])\n  : [];\nconst cBlock = constraints.length\n  ? '\\n\\nConstraints:\\n' + constraints.map(c => '- ' + c).join('\\n')\n  : '';\n\nfunction block(yaml, section, key) {\n  const re = new RegExp(section + ':[\\\\s\\\\S]*?\\\\n  ' + key + ': \\\\|\\\\n((?:    .*\\\\n|\\\\n)*)');\n  const m = yaml.match(re);\n  if (!m) return '';\n  return m[1].replace(/^    /gm, '').trimEnd();\n}\n\nfunction levelSystem(yaml, agent, level) {\n  const re = new RegExp(\n    agent + ':[\\\\s\\\\S]*?levels:[\\\\s\\\\S]*?\\\\n    [\\'\"]?' + level + '[\\'\"]?:\\\\n      system: \\\\|\\\\n((?:        .*\\\\n|\\\\n)*)'\n  );\n  const m = yaml.match(re);\n  if (!m) return '';\n  return m[1].replace(/^        /gm, '').trimEnd();\n}\n\n// Extract all 10 per-level system prompts for explainer and chat.\n// Level selection happens in NormalizeInput (after merge with webhook),\n// where the level value from the request body is available.\nconst explainer_systems = {};\nconst chat_systems = {};\nfor (let lvl = 1; lvl <= 10; lvl++) {\n  const key = String(lvl);\n  explainer_systems[key] = (levelSystem(raw, 'explainer', key) || '') + cBlock;\n  chat_systems[key] = (levelSystem(raw, 'chat', key) || '') + cBlock;\n}\n\nconst explainer_user_template = block(raw, 'explainer', 'user_template');\nconst mermaid_system = block(raw, 'mermaid', 'system') + cBlock;\nconst mermaid_user_template = block(raw, 'mermaid', 'user_template');\nconst chat_user_template = block(raw, 'chat', 'user_template');\n\nreturn [{\n  json: {\n    explainer_systems,\n    explainer_user_template,\n    mermaid_system,\n    mermaid_user_template,\n    chat_systems,\n    chat_user_template,\n  },\n}];"
      },
