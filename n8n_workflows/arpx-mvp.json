    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const item = $input.first().json;\nconst systemPrompt = (item.chat_system || '').trim();\nconst paperExcerpt = String(item.paper_excerpt || '');\nconst userMsg = (item.chat_user_template || '')\n  .replace('{paper_excerpt}', paperExcerpt)\n  .replace('{level}', item.level || '5')\n  .replace('{query}', item.query || '');\nlet history = [];\ntry { const parsed = JSON.parse(item.history || '[]'); if (Array.isArray(parsed)) history = parsed; } catch (e) {}\nconst messages = [\n  { role: 'system', content: systemPrompt },\n  ...history,\n  { role: 'user', content: userMsg }\n];\nreturn [{ json: { messages } }];"
      },
