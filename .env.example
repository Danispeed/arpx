# Copy to `.env` in the project root. Loaded by python-dotenv in `agents/analyzer.py`.

# =============================================================================
# Streamlit app (required to run the web interface)
# =============================================================================

# Secret key that authenticates your app to the Azure OpenAI resource.
# Paste the full key string you were given.
AZURE_OPENAI_KEY=

# HTTPS base URL of your Azure OpenAI resource, with no path after the host.
# Copy the "Endpoint" from Azure Portal → your OpenAI resource → Keys and endpoint.
# It is often https://YOUR_RESOURCE_NAME.openai.azure.com/ but some resources use *.cognitiveservices.azure.com.
AZURE_OPENAI_ENDPOINT=

# Azure chat deployment name the Streamlit app uses when you click **Analyze Paper** to get topics.
# It is a short identifier string, not the model family name by itself. Use the **gpt-4.1-mini** line from the deployment list received from course staff.
AZURE_OPENAI_DEPLOYMENT=

# Optional. Date-stamped REST API version string Azure expects on requests (e.g. 2024-02-01).
# Set only if you need to override the hardcoded default in `agents/analyzer.py`; otherwise leave empty.
AZURE_OPENAI_API_VERSION=2024-10-21

# =============================================================================
# Eval & prompt optimization pipeline (required to run evals/run.py and evals/optimize.py)
# =============================================================================

# Model used to generate explanations and diagrams during evaluation.
# Must be a deployment name available in your Azure account.
# Default: gpt-5-chat (matches the n8n production deployment).
ARPX_GENERATOR_MODEL=gpt-5-chat

# Model used as the LLM judge when scoring rubric dimensions.
# Should be a DIFFERENT model family from ARPX_GENERATOR_MODEL to avoid
# self-fingerprint bias (the judge rewarding its own stylistic choices).
ARPX_JUDGE_MODEL=DeepSeek-V3.2

# Model used by DSPy to propose new prompt variants during optimization.
# A cheaper/faster model is fine here. Default: gpt-4.1-mini.
ARPX_PROPOSER_MODEL=gpt-4.1-mini

# Maximum number of parallel Azure API calls during evaluation.
# Reduce to 1 if you hit 429 rate-limit errors. Default: 3.
ARPX_EVAL_CONCURRENCY=3
